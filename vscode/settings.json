{
  // ============================================================
  // VSCode user settings — symlinked to
  //   ~/Library/Application Support/Code/User/settings.json
  // Per-project config (ESLint/Prettier/ruff/tsconfig) always wins;
  // these are sane global defaults that defer to project tooling.
  // ============================================================

  // ----- Editor -----
  "editor.fontFamily": "Hack Nerd Font, Menlo, monospace",
  "editor.fontSize": 14,
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.rulers": [88, 120],
  "editor.renderWhitespace": "trailing",
  "editor.stickyScroll.enabled": true,
  "editor.linkedEditing": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // ----- Theme & UI -----
  "workbench.colorTheme": "Nord",
  "workbench.iconTheme": "vs-seti",
  "terminal.integrated.fontFamily": "Hack Nerd Font",

  // ----- EditorConfig (respects repo .editorconfig) -----
  "editor.detectIndentation": true,

  // ----- Git -----
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // ----- Web (TypeScript / JS / Vue / React): Prettier + ESLint -----
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[vue]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[scss]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[yaml]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[markdown]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "eslint.useFlatConfig": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.tsserver.experimental.enableProjectDiagnostics": true,
  "npm.packageManager": "pnpm",

  // ----- Python: ruff + uv venvs (Astral toolchain) -----
  "[python]": { "editor.defaultFormatter": "charliermarsh.ruff" },
  "ruff.nativeServer": "on",
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.typeCheckingMode": "basic",

  // ----- Go: gopls + golangci-lint -----
  "[go]": { "editor.defaultFormatter": "golang.go" },
  "go.useLanguageServer": true,
  "go.formatTool": "goimports",
  "go.lintTool": "golangci-lint",
  "go.lintOnSave": "package",
  "gopls": {
    "ui.semanticTokens": true,
    "formatting.gofumpt": true
  },

  // ----- TOML -----
  "[toml]": { "editor.defaultFormatter": "tamasfe.even-better-toml" },

  // ----- Misc -----
  "telemetry.telemetryLevel": "off",
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false
}
