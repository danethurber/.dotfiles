[alias]
    # ===== Branching =====
    branches = branch -a
    bug = "!f() { git checkout -b bug/$1; }; f"
    feature = "!f() { git checkout -b feature/$1; }; f"
    refactor = "!f() { git checkout -b refactor/$1; }; f"
    sw = switch                                    # modern checkout for branches
    swc = switch -c                                # create and switch to new branch

    # ===== Branch Cleanup =====
    # Delete merged branches (excludes main/master and current)
    branch-cleanup = "!f(){ \
      DEFAULT=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@'); \
      git branch --merged | grep -vE \"^\\*|${DEFAULT:-main}|master\" | xargs -r git branch -d; \
    }; f"
    # Force delete unmerged branches (CAUTION)
    branch-cleanup-force = "!f(){ \
      DEFAULT=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@'); \
      git branch | grep -vE \"^\\*|${DEFAULT:-main}|master\" | xargs -r git branch -D; \
    }; f"
    prune = fetch --prune                          # remove stale remote tracking branches

    # ===== Committing =====
    amend = commit --amend --no-edit               # add staged changes to last commit
    ca = !git add -A && git commit -av             # stage all and commit
    co = checkout
    uncommit = reset --soft HEAD~1                 # undo last commit, keep changes staged

    # ===== Diffing =====
    d = diff
    dc = diff --cached                             # diff staged changes
    di = "!d() { git diff HEAD~${1:-1}; }; d"      # diff N commits back (default: 1)

    # ===== History / Logging =====
    l = log --pretty='format:%C(yellow)%h %Creset- %C(white)%s %C(bold blue)[%an]%Creset %Cgreen%cr' -n 20 --graph
    ll = log --pretty=format:'%C(yellow)%h%Cred%d %Creset%s%Cblue [%cn]' --decorate --numstat

    # ===== Info =====
    aliases = "!git config -l | grep alias | cut -c 7-"
    remotes = remote -v
    tags = tag -l

    # ===== Merging =====
    ours = "!f() { git checkout --ours $@ && git add $@; }; f"
    theirs = "!f() { git checkout --theirs $@ && git add $@; }; f"

    # ===== Pulling / Syncing =====
    p = pull
    pf = pull --ff-only                            # fast-forward only (safe)

    # ===== Rebasing =====
    reb = "!r() { git rebase -i HEAD~$1; }; r"     # interactive rebase last N commits

    # ===== Resetting (DANGER ZONE) =====
    stfu = reset --hard HEAD                       # discard ALL uncommitted changes

    # ===== Stashing =====
    snapshot = !git stash push -m \"snapshot: $(date)\" && git stash apply stash@{0}
    stash-unstaged = stash push --keep-index       # stash only unstaged changes

    # ===== Status =====
    s = status -s                                  # short status

    # ===== Tracking =====
    assume = update-index --assume-unchanged       # ignore local changes to tracked file
    assumed = "!git ls-files -v | grep ^h | cut -c 3-"
    unassume = update-index --no-assume-unchanged

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow black
    frag = magenta black
    old = red black
    new = green black

[color "status"]
    plain = white
    added = yellow
    changed = green
    untracked = cyan

[commit]
    # Verify commits using gpg key
    gpgSign = true

[diff]
    tool = vimdiff

[difftool]
    prompt = false

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta

[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    syntax-theme = Nord

[interactive]
    diffFilter = delta --color-only

[merge]
    log = true
    tool = diffconflicts

[mergetool]
	keepBackup = false

[mergetool "diffconflicts"]
	cmd = nvim -c DiffConflicts \"$MERGED\" \"$BASE\" \"$LOCAL\" \"$REMOTE\"
	trustExitCode = true

[push]
    default = simple
    followTags = true

[status]
    # show untracked files inside newly created folders
    showUntrackedFiles = all

[core]
    editor = nvim
    excludesfile = ~/.dotfiles/.gitignore
    # Treat spaces before tabs, lines that are indented with 8 or more spaces, and all kinds of trailing whitespace as an error
    whitespace = space-before-tab,indent-with-non-tab,trailing-space

[log]
    abbrevCommit = true
    date = short

[web]
    browser = google-chrome
